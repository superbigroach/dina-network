#
# This file is managed by Ansible. Manual edits will be overwritten.
# =============================================================================
version: "3.8"

services:
  dina-rpc:
    image: {{ dina_node_image }}
    container_name: dina-rpc
    restart: unless-stopped
    network_mode: host
    volumes:
      - {{ dina_data_dir }}:/data
    environment:
      RUST_LOG: "info,dina_rpc=debug"
      DINA_CHAIN_ID: "{{ dina_chain_id }}"
    command: >-
      --data-dir=/data
      --listen=/ip4/0.0.0.0/tcp/{{ dina_p2p_port }}
      --rpc-port={{ dina_rpc_port }}
      --rest-port={{ dina_rest_port }}
      --chain-id={{ dina_chain_id }}
      --bootstrap=/ip4/{{ hostvars['validator-0']['ansible_host'] }}/tcp/{{ dina_p2p_port }}
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:{{ dina_rest_port }}/health"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 15s
