#
# This file is managed by Ansible. Manual edits will be overwritten.
# =============================================================================
version: "3.8"

services:
  dina-validator:
    image: {{ dina_node_image }}
    container_name: dina-validator
    restart: unless-stopped
    network_mode: host
    volumes:
      - {{ dina_data_dir }}:/data
      - {{ dina_keys_dir }}:/keys:ro
    environment:
      RUST_LOG: "{{ dina_log_level }}"
      DINA_CHAIN_ID: "{{ dina_chain_id }}"
      DINA_VALIDATOR_INDEX: "{{ dina_validator_index }}"
    command: >-
      --data-dir=/data
      --listen=/ip4/0.0.0.0/tcp/{{ dina_p2p_port }}
      --rpc-port={{ dina_rpc_port }}
      --rest-port={{ dina_rest_port }}
      --validator
      --validator-key=/keys/node_key
      --chain-id={{ dina_chain_id }}
      {{ dina_bootstrap_args }}
    healthcheck:
      test: ["CMD", "curl", "-sf", "http://localhost:{{ dina_rest_port }}/health"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 30s
